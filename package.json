{
  "name": "denarius-finance-saas",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:full": "concurrently -n WEB,API -c auto \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "tsx server/index.ts",
    "server": "tsx server/index.ts",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "audit": "npm audit",
    "check:deploy": "npm run typecheck && npm test && npm run build && npm audit --omit=dev"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@vitejs/plugin-react": "5.1.1",
    "bcryptjs": "^3.0.3",
    "clsx": "2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.2",
    "nodemailer": "^9.0.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "3.4.0",
    "tailwindcss": "4.1.17",
    "tsx": "^4.23.0",
    "vite": "^7.3.6",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "22.19.17",
    "@types/nodemailer": "^7.0.4",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "concurrently": "^9.2.1",
    "typescript": "5.9.3",
    "vite-plugin-singlefile": "2.3.0",
    "vitest": "^4.1.8"
  }
}
